# ~/bin/camera-stream-publish.sh

#!/usr/bin/env bash
trap 'kill 0' EXIT

# Right camera publisher
ros2 run gscam gscam_node --ros-args \
  -r __node:=gscam_right \
  -r camera/image_raw:=/camera/right/image_raw \
  -r camera/camera_info:=/camera/right/camera_info \
  -p gscam_config:="decklinkvideosrc device-number=0 ! videoconvert" \
  -p image_encoding:=rgb8 \
  -p frame_id:=right_camera_frame &
RIGHT_CAM_PID=$!

# Left camera publisher
ros2 run gscam gscam_node --ros-args \
  -r __node:=gscam_left \
  -r camera/image_raw:=/camera/left/image_raw \
  -r camera/camera_info:=/camera/left/camera_info \
  -p gscam_config:="decklinkvideosrc device-number=1 ! videoconvert" \
  -p image_encoding:=rgb8 \
  -p frame_id:=left_camera_frame &
LEFT_CAM_PID=$!

sleep 2

# Viewer windows
ros2 run image_view image_view --ros-args -r image:=/camera/left/image_raw &
LEFT_VIEW_PID=$!

ros2 run image_view image_view --ros-args -r image:=/camera/right/image_raw &
RIGHT_VIEW_PID=$!

wait $RIGHT_CAM_PID $LEFT_CAM_PID $LEFT_VIEW_PID $RIGHT_VIEW_PID

